GEMINI_API_KEY=

# DEV: Variáveis de ambiente para o sistema de alertas do Gênesis
# Configurações do Banco de Dados MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=genesis_db
MYSQL_PORT=3306

# Configurações do Telegram
# 1. Abra o Telegram e busque por @BotFather
# 2. Envie o comando /newbot e siga as instruções para criar e dar um nome
# 3. Copie o token HTTP API gerado e cole abaixo em TELEGRAM_TOKEN
# 4. Busque por @userinfobot (ou similar) no Telegram para descobrir seu CHAT ID e cole em TELEGRAM_CHAT_ID
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Autenticação (deve ser uma string aleatória longa de pelo menos 32 caracteres)
JWT_SECRET=

# URL da API do LastLink para verificação de membros
LASTLINK_API_URL=
# Chave de acesso à API do LastLink
LASTLINK_API_KEY=
# Identificador único do administrador no LastLink
ADMIN_USER_ID=

# URL do frontend da Versão 1 (Gênesis 1.0)
VITE_V1_URL=
