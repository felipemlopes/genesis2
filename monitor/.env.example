# Configuracoes do Banco de Dados MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=genesis_db
MYSQL_PORT=3306

# URL do backend Laravel (onde o worker envia alertas via POST)
LARAVEL_API_URL=http://localhost:8000/api

# Gemini — classificacao e traducao (Radar News V1.0, Aviso 2)
# A chamada usa o MESMO formato da API Gemini (generateContent); so o destino
# muda. GEMINI_API_URL deve apontar para a API INTERNA Genesis (baixo custo).
# Sem essa variavel, o worker cai no endpoint oficial do Google como fallback
# de desenvolvimento — NAO USAR isso em producao (o radar roda a cada 3 min).
GEMINI_API_KEY=
GEMINI_API_URL=
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash

# Configuracoes do Telegram
# 1. Abra o Telegram e busque por @BotFather
# 2. Envie o comando /newbot e siga as instrucoes para criar e dar um nome
# 3. Copie o token HTTP API gerado e cole abaixo em TELEGRAM_TOKEN
# 4. Busque por @userinfobot (ou similar) no Telegram para descobrir seu CHAT ID e cole em TELEGRAM_CHAT_ID
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
